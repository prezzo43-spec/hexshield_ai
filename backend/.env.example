# -----------------------------------------------------------------------------
# APPLICATION
# -----------------------------------------------------------------------------
APP_NAME="HexShield AI"
APP_VERSION="1.0.0"
APP_ENV="development"
# Options: development | staging | production
DEBUG=True
SECRET_KEY="replace-this-with-a-long-random-secret-key-minimum-64-characters"


# -----------------------------------------------------------------------------
# DATABASE — Neon PostgreSQL
# Get these values from your Neon project dashboard at https://neon.tech
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://username:password@host/dbname?sslmode=require"
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_ECHO=False
# Set DATABASE_ECHO=True during development to log all SQL queries


# -----------------------------------------------------------------------------
# AUTHENTICATION
# -----------------------------------------------------------------------------
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM="HS256"


# -----------------------------------------------------------------------------
# FILE STORAGE
# -----------------------------------------------------------------------------
UPLOAD_DIR="storage/uploads"
REPORTS_DIR="storage/reports"
MAX_UPLOAD_SIZE_MB=500


# -----------------------------------------------------------------------------
# LAYER 1 — HEX TRIAGE ENGINE
# -----------------------------------------------------------------------------
ENTROPY_ELEVATED_THRESHOLD=6.5
ENTROPY_CRITICAL_THRESHOLD=7.2
MAGIC_BYTES_READ_LENGTH=32
# Number of bytes read from file start for magic byte identification


# -----------------------------------------------------------------------------
# LAYER 2 — AI MEDIA ENGINE
# -----------------------------------------------------------------------------
AI_MODEL_WEIGHTS_DIR="app/services/ai_engine/weights"
AI_CONFIDENCE_THRESHOLD=0.75
AI_INFERENCE_DEVICE="cpu"
# Options: cpu | cuda:0 | mps
AI_ALLOWED_MODEL_WEIGHTS_HASHES=""
AI_MODEL_WEIGHTS_PUBLIC_KEY_PATH="app/services/ai_engine/weights/model_weights_pubkey.pem"
AI_MODEL_WEIGHTS_SIGNATURE_EXTENSION=".sig"
MAX_REQUEST_BODY_SIZE_MB=520
MAX_FORM_FIELDS=100
ALLOWED_UPLOAD_EXTENSIONS=".jpg,.jpeg,.png,.bmp,.webp,.tiff,.tif,.pdf,.txt,.json,.csv,.log,.mp4,.mov,.avi,.wav,.mp3,.flac,.docx,.doc"
ALLOWED_UPLOAD_MIME_PREFIXES="image/,video/,audio/,application/pdf,application/msword,application/vnd.openxmlformats-officedocument,text/,application/json,application/csv,application/octet-stream"


# -----------------------------------------------------------------------------
# LAYER 3 — FORENSIC REPORTING
# -----------------------------------------------------------------------------
REPORT_ISSUING_AUTHORITY="HexShield AI Forensic Platform"
REPORT_JURISDICTION="Republic of Kenya"
CHAIN_OF_CUSTODY_STRICT_MODE=True


# -----------------------------------------------------------------------------
# CORS — Allowed frontend origins
# -----------------------------------------------------------------------------
ALLOWED_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"


# -----------------------------------------------------------------------------
# LOGGING
# -----------------------------------------------------------------------------
LOG_LEVEL="INFO"
# Options: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_FILE="logs/hexshield.log"